# CONFIGURACIÓN GMA DYNAMICS — copiar a .env y completar (NUNCA versionar .env)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-tu-public-key
VITE_N8N_WEBHOOK_URL=https://tu-n8n.example.com/webhook/gma

# Los secretos de servidor (MP_ACCESS_TOKEN, MP_WEBHOOK_SECRET,
# SUPABASE_SERVICE_ROLE_KEY) NO van aquí: se configuran en
